package i.vk.service;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import i.vk.bookrepository.BookRepository;
import i.vk.dto.BookDTO;

@Service
public class BookService {
	@Autowired
	private BookRepository bookRepo;
	
	public BookService(BookRepository bookRepo) {
		this.bookRepo = bookRepo;
	}
	
	public void saveBookService(BookDTO book) {
		if(!bookRepo.existsById(book.getBookId())) {
			System.out.println("\tBook Details are saved in DB");
			bookRepo.save(book);
		}else {
			System.out.println("\tExisting Book...");
		}
	}

}
